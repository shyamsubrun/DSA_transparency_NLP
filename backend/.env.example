# Copy to .env and fill in values.
# After npm install, Prisma client is generated via postinstall (or run: npx prisma generate).

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dsa"
PORT=3001
NODE_ENV=development

# Required for POST /api/analytics/chart-plan and /api/analytics/custom-chart (LLM).
OPENAI_API_KEY=
# Optional overrides:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

FRONTEND_URL=http://localhost:5173

# Mock dashboard mode is configured on the Vite frontend only:
# use frontend/.env or frontend/.env.local with VITE_USE_MOCK_DATA=true
# (This file is for the Node server; VITE_* variables are not read here.)
